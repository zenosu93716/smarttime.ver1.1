rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (required)
    //   - name: string (required)
    //   - role: string (required, enum: '일반직원', '팀장', '부팀장', '사례관리사', '파트장')
    //   - department: string (optional)
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (required)
    //
    // Collection: schedules
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required, immutable)
    //   - userName: string (required)
    //   - title: string (required)
    //   - description: string (optional)
    //   - date: string (required, YYYY-MM-DD)
    //   - fileUrl: string (optional)
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (required)
    //
    // Collection: auth_logs
    // Document ID: auto-generated
    // Fields:
    //   - email: string (required)
    //   - status: string (required, enum: 'SUCCESS', 'FAIL')
    //   - timestamp: timestamp (required, immutable)
    //
    // Collection: error_logs
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (optional)
    //   - errorMessage: string (required)
    //   - context: string (optional)
    //   - timestamp: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['팀장', '부팀장', '사례관리사', '파트장'] ||
        (request.auth.token.email == "youngbosu2@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['email', 'name', 'role', 'department', 'createdAt', 'updatedAt']) &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.role in ['일반직원', '팀장', '부팀장', '사례관리사', '파트장'] &&
             (!('department' in data) || (data.department is string && data.department.size() <= 50)) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidSchedule(data) {
      return hasOnlyAllowedFields(['userId', 'userName', 'title', 'description', 'date', 'fileUrl', 'createdAt', 'updatedAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 50 &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() < 50 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             (!('fileUrl' in data) || (data.fileUrl is string && data.fileUrl.size() <= 500)) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidAuthLog(data) {
      return hasOnlyAllowedFields(['email', 'status', 'timestamp']) &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.status in ['SUCCESS', 'FAIL'] &&
             data.timestamp is timestamp;
    }

    function isValidErrorLog(data) {
      return hasOnlyAllowedFields(['userId', 'errorMessage', 'context', 'timestamp']) &&
             (!('userId' in data) || (data.userId is string && data.userId.size() <= 50)) &&
             data.errorMessage is string && data.errorMessage.size() > 0 && data.errorMessage.size() < 1000 &&
             (!('context' in data) || (data.context is string && data.context.size() <= 1000)) &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && 
                    isOwner(userId) && 
                    isValidUser(request.resource.data) && 
                    (request.resource.data.role == '일반직원' || isAdmin());
      allow update: if isAuthenticated() && 
                    isValidUser(request.resource.data) && 
                    areImmutableFieldsUnchanged(['createdAt']) &&
                    (
                      (isOwner(userId) && areImmutableFieldsUnchanged(['role'])) || 
                      isAdmin()
                    );
      allow delete: if isAdmin();
    }

    match /schedules/{scheduleId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && 
                    request.resource.data.userId == request.auth.uid &&
                    isValidSchedule(request.resource.data);
      allow update: if isAuthenticated() && 
                    isValidSchedule(request.resource.data) && 
                    areImmutableFieldsUnchanged(['userId', 'createdAt']) &&
                    (isDocOwner() || isAdmin());
      allow delete: if isDocOwner() || isAdmin();
    }

    match /auth_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isValidAuthLog(request.resource.data); // Allow creation even if not authenticated (for failed logins)
      allow update, delete: if false; // Logs should be immutable
    }

    match /error_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isValidErrorLog(request.resource.data);
      allow update, delete: if false; // Logs should be immutable
    }
  }
}
