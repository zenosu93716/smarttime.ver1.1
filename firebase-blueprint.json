{
  "entities": {
    "User": {
      "title": "User",
      "description": "Employee profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "part": { "type": "string", "enum": ["1파트", "2파트", "3파트", "4파트", "5파트", "팀장", "부팀장", "기타"] },
        "position": { "type": "string", "enum": ["팀장", "부팀장", "파트장", "상담사", "팀원"] },
        "profilePic": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role", "part", "position", "createdAt"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "Employee work or leave schedule",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "part": { "type": "string" },
        "type": { "type": "string", "enum": ["1근", "2근", "야근", "휴일근무", "연차", "시간연차", "병가", "시간병가", "공가", "특별휴가", "출산전후휴가", "배우자출산휴가", "가족돌봄휴가", "생리휴가", "포상휴가"] },
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "part", "type", "date", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "/schedules/{scheduleId}": {
      "schema": { "$ref": "#/entities/Schedule" },
      "description": "Stores employee schedules"
    }
  }
}
