{
  "entities": {
    "User": {
      "title": "User",
      "description": "사용자 정보",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "이메일" },
        "name": { "type": "string", "description": "이름" },
        "role": { "type": "string", "enum": ["일반직원", "팀장", "부팀장", "사례관리사", "파트장"], "description": "권한" },
        "department": { "type": "string", "description": "부서" },
        "createdAt": { "type": "string", "format": "date-time", "description": "생성일" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "수정일" }
      },
      "required": ["email", "name", "role", "createdAt", "updatedAt"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "일정 정보",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "사용자 ID" },
        "userName": { "type": "string", "description": "사용자 이름" },
        "title": { "type": "string", "description": "일정 제목" },
        "description": { "type": "string", "description": "일정 상세" },
        "date": { "type": "string", "description": "날짜 (YYYY-MM-DD)" },
        "fileUrl": { "type": "string", "description": "첨부파일 URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "생성일" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "수정일" }
      },
      "required": ["userId", "userName", "title", "date", "createdAt", "updatedAt"]
    },
    "AuthLog": {
      "title": "AuthLog",
      "description": "로그인 기록",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "이메일" },
        "status": { "type": "string", "enum": ["SUCCESS", "FAIL"], "description": "상태" },
        "timestamp": { "type": "string", "format": "date-time", "description": "시간" }
      },
      "required": ["email", "status", "timestamp"]
    },
    "ErrorLog": {
      "title": "ErrorLog",
      "description": "에러 기록",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "사용자 ID" },
        "errorMessage": { "type": "string", "description": "에러 메시지" },
        "context": { "type": "string", "description": "상황/위치" },
        "timestamp": { "type": "string", "format": "date-time", "description": "시간" }
      },
      "required": ["errorMessage", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "사용자 컬렉션"
    },
    "schedules/{scheduleId}": {
      "schema": { "$ref": "#/entities/Schedule" },
      "description": "일정 컬렉션"
    },
    "auth_logs/{logId}": {
      "schema": { "$ref": "#/entities/AuthLog" },
      "description": "로그인 기록 컬렉션"
    },
    "error_logs/{logId}": {
      "schema": { "$ref": "#/entities/ErrorLog" },
      "description": "에러 기록 컬렉션"
    }
  }
}
